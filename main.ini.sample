[Paths]
Projects = C:\Development\Projects
Documents = C:\Users\YourUser\Documents
Downloads = C:\Users\YourUser\Downloads

[Commands]
v = VSCODE, code {path}
a = Antigravity, antigravity {path}

[SyncCommands]
g = GitStatus, git status
d = Linux-DU, powershell -NoProfile -ExecutionPolicy Bypass -Command "Get-ChildItem -Depth {{Depth}} -Force | ForEach-Object { $rel = Resolve-Path $_.FullName -Relative; if ($_.PSIsContainer) { $size = (Get-ChildItem -LiteralPath $_.FullName -Recurse -Force -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum } else { $size = $_.Length }; [PSCustomObject]@{ Path = $rel; SizeMB = [math]::round(($size / 1MB), 3) } } | Sort-Object Path | Format-Table -AutoSize"
f = FullDu-Csv, cmd /k powershell -NoProfile -ExecutionPolicy Bypass -Command "Get-ChildItem -Recurse | ForEach-Object { $rel = Resolve-Path $_.FullName -Relative; $depth = ($rel -replace '^\.\\', '' -split '\\').Count - 1; if($rel -eq '.\' -or $rel -notlike '*\*'){$depth=0}; $type = if($_.PSIsContainer){'d'}else{'f'}; $sz = if($_.PSIsContainer){(gci $_.FullName -Recurse -Force -EA 0 | Measure-Object Length -Sum).Sum}else{$_.Length}; [PSCustomObject]@{ 'Parent' = $_.DirectoryName -replace [regex]::Escape((Get-Location).Path), '.'; 'Depth' = $depth; 'Type' = $type; 'Name' = $_.Name; 'SizeMB' = [math]::round($sz / 1MB, 3) } } | ConvertTo-Csv -NoTypeInformation | ForEach-Object { $_ -replace '\"(\d+\.?\d*)\"', '$1' }"
p = Ping-Sweep, powershell -NoProfile -ExecutionPolicy Bypass -Command "{{Range(1..254)}} | ForEach-Object { $ip='{{Network(ex:192.168.0)}}'+'.'+$_; $p = Test-Connection $ip -Count 1 -ErrorAction SilentlyContinue; if($p){ $hostn = try { [System.Net.Dns]::GetHostEntry($ip).HostName } catch { 'N/A' }; [PSCustomObject]@{ IP=$ip; Resp=$p.ResponseTime; TTL=$p.ResponseTimeToLive; Host=$hostn } } } | ConvertTo-Csv -NoTypeInformation | ForEach-Object { $_ -replace '\"(\d+)\"', '$1' }"
r = Tree, powershell -NoProfile -ExecutionPolicy Bypass -Command "Get-ChildItem -Depth {{Depth}} -Force | ForEach-Object { $indent = '  ' * (($_.FullName -replace [regex]::Escape((Get-Location).Path), '').Split('\').Count - 2); $p = if($_.PSIsContainer){'d'}else{'-'}; $p += if($_.IsReadOnly){'r--'}else{'rw-'}; $p += 'r--r--'; $size = if($_.PSIsContainer){ '--' }else{ [math]::round($_.Length / 1MB, 3).ToString() + 'MB' }; $c = $_.CreationTime.ToString('yyyy/MM/dd HH:mm'); $m = $_.LastWriteTime.ToString('yyyy/MM/dd HH:mm'); Write-Host ($indent + '[' + $p + '] ' + $_.Name + ' (' + $size + ') [C:' + $c + '] [M:' + $m + ']') };"
