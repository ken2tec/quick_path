# quick_path configuration file
# Rename this file to quick_path.ini to use.
[Paths]
Projects = C:\Development\Projects
Documents = C:\Users\YourUser\Documents
Downloads = C:\Users\YourUser\Downloads

[Commands]
v = VSCODE, code {path}
a = Antigravity, antigravity {path}
x = XlsxToCsv, powershell -NoProfile -ExecutionPolicy Bypass -Command "$p=(Resolve-Path '{path}').Path; $c=$p -replace '\.(xlsx|xls)$', '.csv'; if(Test-Path $c){ Remove-Item $c -Force }; $e=New-Object -ComObject Excel.Application; $e.Visible=$false; $e.DisplayAlerts=$false; try { $w=$e.Workbooks.Open($p, 0, $true); $ws=$w.Sheets.Item('{{Sheet Name}}'); $ws.Copy(); $newWb=$e.ActiveWorkbook; $newWb.SaveAs($c, 6); $newWb.Close($false); Write-Host 'Success: ' $c } catch { Write-Host 'Error: ' $_.Exception.Message } finally { if($w){$w.Close($false)}; $e.Quit(); [System.Runtime.Interopservices.Marshal]::ReleaseComObject($e) | Out-Null; }"

[SyncCommands]
d = LinuxDU, powershell -NoProfile -ExecutionPolicy Bypass -Command "Get-ChildItem -Depth {{Depth}} -Force | ForEach-Object { $rel = Resolve-Path $_.FullName -Relative; if ($_.PSIsContainer) { $size = (Get-ChildItem -LiteralPath $_.FullName -Recurse -Force -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum } else { $size = $_.Length }; [PSCustomObject]@{ Path = $rel; SizeMB = [math]::round(($size / 1MB), 3) } } | Sort-Object Path | Format-Table -AutoSize"
f = FullDuToCsv, powershell -NoProfile -ExecutionPolicy Bypass -Command "$root=(Get-Location).Path; Get-ChildItem -Recurse -ErrorAction SilentlyContinue | ForEach-Object { $rel = $_.FullName -replace [regex]::Escape($root), ''; $depth = ($rel.Split('\', [System.StringSplitOptions]::RemoveEmptyEntries)).Count - 1; $p = $_.DirectoryName -replace [regex]::Escape($root), '.'; if($p -eq ''){$p='.'}; $type = if($_.PSIsContainer){'d'}else{'f'}; $sz = if($_.PSIsContainer){(gci $_.FullName -Recurse -Force -EA 0 | Measure-Object Length -Sum).Sum}else{$_.Length}; [PSCustomObject]@{ 'Parent' = $p; 'Depth' = [Math]::Max(0, $depth); 'Type' = $type; 'Name' = $_.Name; 'SizeMB' = [math]::round($sz / 1MB, 3) } } | ConvertTo-Csv -NoTypeInformation | ForEach-Object { $_ -replace '\"(\d+\.?\d*)\"', '$1' }"
p = PingSweep, powershell -NoProfile -ExecutionPolicy Bypass -Command "{{Range(1..254)}} | ForEach-Object { $ip='{{Network(ex:192.168.0)}}'+'.'+$_; $p = Test-Connection $ip -Count 1 -ErrorAction SilentlyContinue; if($p){ $hostn = try { [System.Net.Dns]::GetHostEntry($ip).HostName } catch { 'N/A' }; [PSCustomObject]@{ IP=$ip; Resp=$p.ResponseTime; TTL=$p.ResponseTimeToLive; Host=$hostn } } } | ConvertTo-Csv -NoTypeInformation | ForEach-Object { $_ -replace '\"(\d+)\"', '$1' }"
r = Tree, powershell -NoProfile -ExecutionPolicy Bypass -Command "$root=(Get-Location).Path; Get-ChildItem -Recurse -Force -ErrorAction SilentlyContinue | Sort-Object FullName | ForEach-Object { $rel = $_.FullName -replace [regex]::Escape($root), ''; $d = ($rel.Split('\',[System.StringSplitOptions]::RemoveEmptyEntries)).Count - 1; $indent = '  ' * [Math]::Max(0, $d); $p1 = if($_.PSIsContainer){'d'}else{'-'}; $p2 = if($_.IsReadOnly){'r--'}else{'rw-'}; $sz = if($_.PSIsContainer){'--'}else{([math]::round($_.Length/1MB,3)).ToString()+'MB'}; $c = $_.CreationTime.ToString('yyyy/MM/dd HH:mm'); $m = $_.LastWriteTime.ToString('yyyy/MM/dd HH:mm'); Write-Host ($indent + '[' + $p1 + $p2 + 'r--r--] ' + $_.Name + ' (' + $sz + ') [C:' + $c + '] [M:' + $m + ']') }"
s = GrepSearch, powershell -NoProfile -ExecutionPolicy Bypass -Command "Get-ChildItem -Recurse -File -ErrorAction SilentlyContinue | Select-String -Pattern {{Search Word}} | ForEach-Object { Write-Host ('[Found] ' + $_.Path + ' (Line:' + $_.LineNumber + ')') -ForegroundColor Cyan; Write-Host ('  > ' + $_.Line.Trim()); Write-Host '' }"
g = GitStatus, git status
